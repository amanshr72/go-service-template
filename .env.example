# Database Connection Configuration
DATABASE_URL="host=localhost user=your_user password=your_password dbname=your_db port=5432 sslmode=disable"
DB_ADAPTER=postgres

# Goose Migration Tool Configuration
GOOSE_DRIVER=postgres
GOOSE_DBSTRING="host=localhost user=your_user password=your_password dbname=your_db sslmode=disable"

# Security & Authentication
JWT_SECRET=your-super-secret-random-key-here

# Application Runtime Setup
APP_ENV=local